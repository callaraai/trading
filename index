<script>
  const TOTAL = 8;
  let current = 1;

  function navigate(dir) {
    document.getElementById('s' + current).classList.remove('active');
    updateNav(current, 'done');
    current += dir;
    if (current < 1) current = 1;
    document.getElementById('s' + current).classList.add('active');
    updateNav(current, 'active');
    updateProgress();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function submitForm() {
    document.getElementById('s8').classList.remove('active');
    updateNav(8, 'done');
    document.getElementById('complete').classList.add('active');
    document.querySelector('.sidebar-footer .progress-fill').style.width = '100%';
    document.getElementById('prog-text').textContent = '8 of 8 complete';
    document.getElementById('prog-pct').textContent = '100%';
    buildSummary();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function updateNav(n, state) {
    const items = document.querySelectorAll('#nav-list .nav-item');
    items.forEach(item => {
      if (parseInt(item.dataset.section) === n) {
        item.classList.remove('active', 'done');
        item.classList.add(state);
      }
    });
  }

  function updateProgress() {
    const pct = Math.round(((current - 1) / TOTAL) * 100);
    document.getElementById('prog-fill').style.width = pct + '%';
    document.getElementById('prog-text').textContent = (current - 1) + ' of ' + TOTAL + ' complete';
    document.getElementById('prog-pct').textContent = pct + '%';
  }

  // Chips
  document.querySelectorAll('.chip').forEach(c => {
    c.addEventListener('click', () => c.classList.toggle('selected'));
  });

  // Radio cards
  document.querySelectorAll('.radio-card').forEach(card => {
    card.addEventListener('click', () => {
      const group = card.closest('.radio-grid');
      group.querySelectorAll('.radio-card').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
    });
  });

  function getSelected(id) {
    const el = document.getElementById(id);
    if (!el) return '—';
    const sel = el.querySelectorAll('.chip.selected, .radio-card.selected');
    return sel.length ? Array.from(sel).map(s => s.querySelector('.radio-main, .chip')?.textContent?.trim() || s.textContent.trim()).join(', ') : '—';
  }

  function getVal(id) {
    const el = document.getElementById(id);
    return el && el.value.trim() ? el.value.trim() : '—';
  }

  const SUMMARY_FIELDS = [
    { label: 'Framework', fn: () => getSelected('methodology') },
    { label: 'Entry setup', fn: () => getVal('entry-setup') },
    { label: 'Timeframes', fn: () => getSelected('timeframes') },
    { label: 'Invalidation', fn: () => getVal('invalidation') },
    { label: 'Risk per trade', fn: () => getSelected('risk-per-trade') },
    { label: 'Stop method', fn: () => getSelected('stop-method') },
    { label: 'Exit method', fn: () => getSelected('exit-method') },
    { label: 'Max loss limit', fn: () => getVal('max-loss') },
    { label: 'Breakeven', fn: () => getSelected('breakeven') },
    { label: 'Sessions', fn: () => getSelected('sessions') },
    { label: 'Pairs', fn: () => getSelected('pairs') },
    { label: 'Top pairs', fn: () => getVal('top-pairs') },
    { label: 'Unavailable', fn: () => getVal('unavailable') },
    { label: 'Platform', fn: () => getSelected('platform') },
    { label: 'API access', fn: () => getSelected('api-access') },
    { label: 'Agent mode', fn: () => getSelected('agent-mode') },
    { label: 'Prop firm', fn: () => getSelected('prop-firm') },
    { label: 'Prop rules', fn: () => getVal('prop-rules') },
    { label: 'Journal status', fn: () => getSelected('journal-status') },
    { label: 'Journal tool', fn: () => getSelected('journal-tool') },
    { label: 'Auto-capture', fn: () => getSelected('capture-data') },
    { label: 'Perf metric', fn: () => getVal('perf-metric') },
    { label: 'Alert channel', fn: () => getSelected('alert-channel') },
    { label: 'Alert threshold', fn: () => getSelected('alert-threshold') },
    { label: 'Alert verbosity', fn: () => getSelected('alert-verbosity') },
    { label: 'In-trade alerts', fn: () => getSelected('intra-alerts') },
    { label: 'Fundamentals', fn: () => getSelected('fundamentals') },
    { label: 'Macro inputs', fn: () => getSelected('macro-inputs') },
    { label: 'News handling', fn: () => getSelected('news-block') },
    { label: 'Max trades/day', fn: () => getVal('max-trades') },
    { label: 'Overtrade pattern', fn: () => getVal('overtrade') },
    { label: 'Deviation flag', fn: () => getSelected('deviation') },
    { label: 'Setup grades', fn: () => getVal('setup-grades') },
    { label: 'Other notes', fn: () => getVal('other-notes') },
  ];

  function buildSummary() {
    const table = document.getElementById('summary-table');
    table.innerHTML = SUMMARY_FIELDS.map(f => {
      const val = f.fn();
      if (val === '—') return '';
      return `<tr><td>${f.label}</td><td>${val}</td></tr>`;
    }).join('');
  }

  function downloadTxt() {
    const lines = [
      'AI FOREX AGENT — TRADER INTAKE SUMMARY',
      '========================================',
      'Generated: ' + new Date().toLocaleString(),
      '',
    ];
    SUMMARY_FIELDS.forEach(f => {
      lines.push(f.label.toUpperCase() + ':');
      lines.push('  ' + f.fn());
      lines.push('');
    });
    const blob = new Blob([lines.join('\n')], { type: 'text/plain' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'trader-intake-summary.txt';
    a.click();
  }

  function downloadJson() {
    const data = {};
    SUMMARY_FIELDS.forEach(f => {
      data[f.label.toLowerCase().replace(/[\s\/]+/g, '_')] = f.fn();
    });
    const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'trader-intake-config.json';
    a.click();
  }
