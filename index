<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>AI Forex Agent — Trader Intake</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0a0a0a;
    --surface: #111111;
    --surface2: #181818;
    --border: rgba(255,255,255,0.08);
    --border-active: rgba(255,255,255,0.3);
    --text: #f0ede8;
    --text-muted: rgba(240,237,232,0.45);
    --text-dim: rgba(240,237,232,0.25);
    --accent: #c8f064;
    --accent-dark: #9bbd3e;
    --mono: 'IBM Plex Mono', monospace;
    --sans: 'IBM Plex Sans', sans-serif;
    --display: 'Syne', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-weight: 400;
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    z-index: 0;
  }

  .layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 280px 1fr;
    min-height: 100vh;
  }

  /* SIDEBAR */
  .sidebar {
    border-right: 1px solid var(--border);
    padding: 2.5rem 2rem;
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    background: rgba(10,10,10,0.85);
    backdrop-filter: blur(12px);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 3rem;
  }

  .brand-mark {
    width: 32px;
    height: 32px;
    background: var(--accent);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .brand-mark svg {
    width: 16px;
    height: 16px;
  }

  .brand-name {
    font-family: var(--display);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--text);
  }

  .nav-list {
    list-style: none;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 9px 12px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    border: 1px solid transparent;
  }

  .nav-item:hover { background: var(--surface2); }

  .nav-item.active {
    background: var(--surface2);
    border-color: var(--border-active);
  }

  .nav-item.done .nav-num {
    background: var(--accent);
    color: #0a0a0a;
    border-color: var(--accent);
  }

  .nav-num {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-muted);
    flex-shrink: 0;
    transition: all 0.2s;
  }

  .nav-item.active .nav-num {
    border-color: var(--text);
    color: var(--text);
  }

  .nav-label {
    font-size: 13px;
    color: var(--text-muted);
    transition: color 0.2s;
    font-weight: 400;
  }

  .nav-item.active .nav-label { color: var(--text); }
  .nav-item.done .nav-label { color: var(--text-muted); }

  .sidebar-footer {
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .progress-label {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dim);
    margin-bottom: 8px;
    display: flex;
    justify-content: space-between;
  }

  .progress-track {
    height: 2px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 2px;
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    width: 0%;
  }

  /* MAIN */
  .main {
    padding: 3rem 4rem;
    max-width: 760px;
  }

  .section {
    display: none;
    animation: fadeSlide 0.35s ease;
  }

  .section.active { display: block; }

  @keyframes fadeSlide {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .section-eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-family: var(--display);
    font-size: 32px;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .section-desc {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 520px;
  }

  .divider {
    height: 1px;
    background: var(--border);
    margin: 2rem 0;
  }

  /* FORM ELEMENTS */
  .q-group {
    margin-bottom: 2rem;
  }

  .q-label {
    font-family: var(--display);
    font-size: 15px;
    font-weight: 600;
    display: block;
    margin-bottom: 4px;
    color: var(--text);
  }

  .q-hint {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 12px;
    line-height: 1.5;
    font-family: var(--mono);
  }

  .q-input, .q-textarea {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-family: var(--sans);
    font-size: 14px;
    padding: 12px 14px;
    outline: none;
    transition: border-color 0.2s;
    line-height: 1.6;
  }

  .q-input:focus, .q-textarea:focus {
    border-color: var(--border-active);
  }

  .q-input::placeholder, .q-textarea::placeholder {
    color: var(--text-dim);
  }

  .q-textarea {
    resize: vertical;
    min-height: 90px;
  }

  /* CHIPS */
  .chip-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .chip {
    padding: 7px 14px;
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.15s;
    color: var(--text-muted);
    background: var(--surface);
    user-select: none;
    font-family: var(--sans);
    white-space: nowrap;
  }

  .chip:hover {
    border-color: var(--border-active);
    color: var(--text);
  }

  .chip.selected {
    background: var(--accent);
    border-color: var(--accent);
    color: #0a0a0a;
    font-weight: 500;
  }

  /* RADIO CARDS */
  .radio-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .radio-card {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 16px;
    border: 1px solid var(--border);
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.15s;
    background: var(--surface);
    user-select: none;
  }

  .radio-card:hover {
    border-color: var(--border-active);
    background: var(--surface2);
  }

  .radio-card.selected {
    border-color: var(--accent);
    background: rgba(200, 240, 100, 0.06);
  }

  .radio-indicator {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 1.5px solid var(--border-active);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
    transition: all 0.15s;
  }

  .radio-card.selected .radio-indicator {
    border-color: var(--accent);
  }

  .radio-card.selected .radio-indicator::after {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
  }

  .radio-content { flex: 1; }

  .radio-main {
    font-size: 14px;
    color: var(--text);
    line-height: 1.4;
  }

  .radio-sub {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 2px;
    font-family: var(--mono);
  }

  /* NAV BUTTONS */
  .nav-buttons {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .btn {
    font-family: var(--display);
    font-size: 14px;
    font-weight: 600;
    padding: 11px 24px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .btn:hover:not(:disabled) {
    border-color: var(--border-active);
    color: var(--text);
  }

  .btn:disabled {
    opacity: 0.2;
    cursor: not-allowed;
  }

  .btn-primary {
    background: var(--accent);
    color: #0a0a0a;
    border-color: var(--accent);
  }

  .btn-primary:hover:not(:disabled) {
    background: #d9ff70;
    border-color: #d9ff70;
    color: #0a0a0a;
  }

  .step-indicator {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text-dim);
  }

  /* COMPLETE SCREEN */
  .complete {
    display: none;
    padding-top: 2rem;
    animation: fadeSlide 0.4s ease;
  }

  .complete.active { display: block; }

  .complete-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: rgba(200,240,100,0.1);
    border: 1px solid rgba(200,240,100,0.3);
    border-radius: 100px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    margin-bottom: 1.5rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .complete-badge::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  .complete h1 {
    font-family: var(--display);
    font-size: 36px;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .complete p {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: 2.5rem;
  }

  .summary-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 2.5rem;
    font-size: 13px;
  }

  .summary-table tr {
    border-bottom: 1px solid var(--border);
  }

  .summary-table td {
    padding: 11px 0;
    vertical-align: top;
  }

  .summary-table td:first-child {
    color: var(--text-muted);
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    width: 160px;
    padding-right: 20px;
    padding-top: 13px;
  }

  .summary-table td:last-child {
    color: var(--text);
    line-height: 1.5;
  }

  .dl-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* RESPONSIVE */
  @media (max-width: 860px) {
    .layout { grid-template-columns: 1fr; }
    .sidebar {
      position: relative;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--border);
      padding: 1.5rem;
      flex-direction: row;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .brand { margin-bottom: 0; }
    .nav-list {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 4px;
      flex: none;
    }
    .nav-item { padding: 6px 10px; }
    .nav-label { display: none; }
    .sidebar-footer { display: none; }
    .main { padding: 2rem 1.5rem; }
    .section-title { font-size: 24px; }
  }
</style>
</head>
<body>

<div class="layout">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="brand">
      <div class="brand-mark">
        <svg viewBox="0 0 16 16" fill="none">
          <path d="M8 2L14 5.5V10.5L8 14L2 10.5V5.5L8 2Z" fill="#0a0a0a"/>
        </svg>
      </div>
      <span class="brand-name">AGENT INTAKE</span>
    </div>

    <ul class="nav-list" id="nav-list">
      <li class="nav-item active" data-section="1">
        <span class="nav-num">1</span>
        <span class="nav-label">Methodology</span>
      </li>
      <li class="nav-item" data-section="2">
        <span class="nav-num">2</span>
        <span class="nav-label">Risk rules</span>
      </li>
      <li class="nav-item" data-section="3">
        <span class="nav-num">3</span>
        <span class="nav-label">Sessions & pairs</span>
      </li>
      <li class="nav-item" data-section="4">
        <span class="nav-num">4</span>
        <span class="nav-label">Execution</span>
      </li>
      <li class="nav-item" data-section="5">
        <span class="nav-num">5</span>
        <span class="nav-label">Journaling</span>
      </li>
      <li class="nav-item" data-section="6">
        <span class="nav-num">6</span>
        <span class="nav-label">Alerts</span>
      </li>
      <li class="nav-item" data-section="7">
        <span class="nav-num">7</span>
        <span class="nav-label">Macro</span>
      </li>
      <li class="nav-item" data-section="8">
        <span class="nav-num">8</span>
        <span class="nav-label">Psychology</span>
      </li>
    </ul>

    <div class="sidebar-footer">
      <div class="progress-label">
        <span id="prog-text">0 of 8 complete</span>
        <span id="prog-pct">0%</span>
      </div>
      <div class="progress-track">
        <div class="progress-fill" id="prog-fill"></div>
      </div>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <main class="main">

    <!-- S1: METHODOLOGY -->
    <div class="section active" id="s1">
      <div class="section-eyebrow">Section 01 / 08</div>
      <h2 class="section-title">Trading methodology</h2>
      <p class="section-desc">This defines the agent's core scanner logic. The more specific you are, the more precisely the agent can identify valid setups on your behalf.</p>

      <div class="q-group">
        <label class="q-label">Primary trading framework</label>
        <div class="q-hint">Select all that apply</div>
        <div class="chip-grid" id="methodology">
          <div class="chip" data-val="ict">ICT concepts</div>
          <div class="chip" data-val="smc">Smart money / SMC</div>
          <div class="chip" data-val="pa">Price action only</div>
          <div class="chip" data-val="sr">Support & resistance</div>
          <div class="chip" data-val="indicators">Indicators-based</div>
          <div class="chip" data-val="algo">Algo / rules-based</div>
          <div class="chip" data-val="wyckoff">Wyckoff</div>
          <div class="chip" data-val="other-meth">Other</div>
        </div>
      </div>

      <div class="q-group">
        <label class="q-label">Describe your entry setup</label>
        <div class="q-hint">What conditions must all be present? This becomes the agent's exact scanner logic — be specific.</div>
        <textarea class="q-textarea" id="entry-setup" placeholder="e.g. HTF bias established on daily, price raids buy-side liquidity, breaks structure on 5m, I enter on the FVG retest with confirmation candle..."></textarea>
      </div>

      <div class="q-group">
        <label class="q-label">Analysis timeframes</label>
        <div class="q-hint">Select all timeframes you use (HTF bias through LTF entry)</div>
        <div class="chip-grid" id="timeframes">
          <div class="chip" data-val="w">Weekly</div>
          <div class="chip" data-val="d">Daily</div>
          <div class="chip" data-val="4h">4H</div>
          <div class="chip" data-val="1h">1H</div>
          <div class="chip" data-val="15m">15M</div>
          <div class="chip" data-val="5m">5M</div>
          <div class="chip" data-val="1m">1M</div>
        </div>
      </div>

      <div class="q-group">
        <label class="q-label">Pre-entry invalidation</label>
        <div class="q-hint">What tells you the trade idea is wrong before you enter?</div>
        <textarea class="q-textarea" id="invalidation" placeholder="e.g. Price closes above previous swing high on 1H, or DXY breaks opposing structure, or setup takes more than 4 hours to develop..."></textarea>
      </div>

      <div class="nav-buttons">
        <button class="btn" disabled>← Back</button>
        <span class="step-indicator">1 / 8</span>
        <button class="btn btn-primary" onclick="navigate(1)">Next →</button>
      </div>
    </div>

    <!-- S2: RISK MANAGEMENT -->
    <div class="section" id="s2">
      <div class="section-eyebrow">Section 02 / 08</div>
      <h2 class="section-title">Risk management</h2>
      <p class="section-desc">The agent uses these rules to size positions, trigger warnings, and enforce circuit breakers.</p>

      <div class="q-group">
        <label class="q-label">Max risk per trade</label>
        <div class="radio-grid" id="risk-per-trade">
          <div class="radio-card" data-val="0.5"><div class="radio-indicator"></div><div class="radio-content"><div class="radio-main">0.5% of account</div><div class="radio-sub">Conservative — common for prop firm challenges</div></div></div>
          <div class="radio-card" data-val="1"><div class="radio-indicator"></div><div class="radio-content"><div class="radio-main">1% of account</div><div class="radio-sub">Standard risk management benchmark</div></div></div>
          <div class="radio-card" data-val="2"><div class="radio-indicator"></div><div class="radio-content"><div class="radio-main">2% of account</div><div class="radio-sub">Aggressive — requires high win rate or R:R</div></div></div>
          <div class="radio-card" data-val="custom-risk"><div class="radio-indicator"></div><div class="radio-content"><div class="radio-main">Custom</div><div class="radio-sub">I'll specify in notes</div></div></div>
        </div>
      </div>

      <div class="q-group">
        <label class="q-label">Stop loss placement method</label>
        <div class="radio-grid" id="stop-method">
          <div class="radio-card" data-val="structure"><div class="radio-indicator"></div><div class="radio-content"><div class="radio-main">Below / above market structure</div></div></div>
          <div class="radio-card" data-val="swing"><div class="radio-indicator"></div><div class="radio-content"><div class="radio-main">Previous swing high / low</div></div></div>
          <div class="radio-card" data-val="atr"><div class="radio-indicator"></div><div class="radio-content"><div class="radio-main">ATR-based</div></div></div>
          <div class="radio-card" data-val="fixed-pips"><div class="radio-indicator"></div><div class="radio-content"><div class="radio-main">Fixed pips</div></div></div>
          <div class="radio-card" data-val="other-stop"><div class="radio-indicator"></div><div class="radio-content"><div class="radio-main">Other</div></div></div>
        </div>
      </div>

      <div class="q-group">
        <label class="q-label">Exit / take profit method</label>
        <div class="radio-grid" id="exit-method">
          <div class="radio-card" data-val="fixed-rr"><div class="radio-indicator"></div><div class="radio-content"><div class="radio-main">Fixed R:R target</div><div class="radio-sub">e.g. always 1:2, always 1:3</div></div></div>
          <div class="radio-card" data-val="dynamic"><div class="radio-indicator"></div><div class="radio-content"><div class="radio-main">Dynamic — managed based on price action</div></div></div>
          <div class="radio-card" data-val="partial"><div class="radio-indicator"></div><div class="radio-content"><div class="radio-main">Scale out at multiple targets</div></div></div>
          <div class="radio-card" data-val="trailing"><div class="radio-indicator"></div><div class="radio-content"><div class="radio-main">Trailing stop</div></div></div>
        </div>
      </div>

      <div class="q-group">
        <label class="q-label">Daily / weekly max loss limit</label>
        <div class="q-hint">Agent will trigger a circuit breaker and halt signals when this is hit</div>
        <input class="q-input" id="max-loss" type="text" placeholder="e.g. 3% daily, 6% weekly" />
      </div>

      <div class="q-group">
        <label class="q-label">Do you move stops to breakeven?</label>
        <div class="radio-grid" id="breakeven">
          <div class="radio-card" data-val="yes-r"><div class="radio-indicator"></div><div class="radio-content"><div class="radio-main">Yes — at a specific R level</div><div class="radio-sub">e.g. once trade reaches 1:1, move stop to entry</div></div></div>
          <div class="radio-card" data-val="yes-pa"><div class="radio-indicator"></div><div class="radio-content"><div class="radio-main">Yes — when price action signals it</div></div></div>
          <div class="radio-card" data-val="no-be"><div class="radio-indicator"></div><div class="radio-content"><div class="radio-main">No — I let it run to original stop</div></div></div>
        </div>
      </div>

      <div class="nav-buttons">
        <button class="btn" onclick="navigate(-1)">← Back</button>
        <span class="step-indicator">2 / 8</span>
        <button class="btn btn-primary" onclick="navigate(1)">Next →</button>
      </div>
    </div>

    <!-- S3: SESSIONS & PAIRS -->
    <div class="section" id="s3">
      <div class="section-eyebrow">Section 03 / 08</div>
      <h2 class="section-title">Sessions & pairs</h2>
      <p class="section-desc">Defines where and when the agent focuses its attention — and when it monitors autonomously while you're unavailable.</p>

      <div class="q-group">
        <label class="q-label">Sessions you actively trade</label>
        <div class="chip-grid" id="sessions">
          <div class="chip" data-val="london">London open</div>
